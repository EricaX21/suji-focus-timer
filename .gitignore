# 依赖：用 npm install 还原，不进版本库
node_modules/

# 打包产物：每次打包重新生成（600M+）
dist/

# 本地测试数据（真实数据在 %APPDATA%\study-timer，不在仓库）
data/
# 隔离测试用数据目录（STUDYTIMER_DATA_DIR 指向这里，与正式版数据分开）
.devdata/

# 编辑器 / 工具本地配置
.obsidian/
.claude/settings.local.json

# 系统杂物
Thumbs.db
desktop.ini
*.log

# 开发自测时的临时截图（调试用，不纳入仓库）
.shot-*.png

# 个人需求草稿（不公开）
计划更新内容.md
